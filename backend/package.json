{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "nodemon src/server.js",
    "seed": "node scripts/seed.js",
    "lint": "eslint src/*.js",
    "test": "NODE_ENV=test node --experimental-vm-modules node_modules/.bin/jest --runInBand --coverage",
    "test:ci": "NODE_ENV=test node --experimental-vm-modules node_modules/.bin/jest --runInBand --coverage --forceExit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "async-lock": "^1.2.4",
    "body-parser": "^1.19.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.17.1",
    "morgan": "^1.10.0",
    "nodemon": "^2.0.6",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "eslint": "^7.12.1",
    "jest": "^29.7.0",
    "jest-html-reporter": "^3.10.2",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "reporters": [
      "default",
      [
        "jest-html-reporter",
        {
          "pageTitle": "ClimateScore API Test Report — F14A_BRAVO",
          "outputPath": "./reports/test-report.html",
          "includeFailureMsg": true
        }
      ]
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js"
    ]
  }
}
